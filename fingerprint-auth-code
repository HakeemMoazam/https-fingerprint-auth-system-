#include <Adafruit_Fingerprint.h>
#include <SoftwareSerial.h>
#include <LiquidCrystal.h>

// --- Hardware Pin Configurations ---
// Fingerprint Sensor: RX to Pin 10, TX to Pin 9
SoftwareSerial fingerSerial(10, 9);
Adafruit_Fingerprint finger = Adafruit_Fingerprint(&fingerSerial);

// Parallel 16x2 LCD layout (RS, Enable, D4, D5, D6, D7)
LiquidCrystal lcd(12, 11, 5, 4, 3, 2);

// --- 4-Button Hardware Configurations ---
const int BTN_ENROLL = 6;  // Button 1: Enter Registration / Confirm
const int BTN_DELETE = 7;  // Button 2: Enter Deletion / Cancel
const int BTN_UP     = 8;  // Button 3: Increment ID number
const int BTN_DOWN   = 13; // Button 4: Decrement ID number

void setup() {
  Serial.begin(9600);
  lcd.begin(16, 2);
  
  // Initialize Buttons with internal pullups (Active LOW configuration)
  pinMode(BTN_ENROLL, INPUT_PULLUP);
  pinMode(BTN_DELETE, INPUT_PULLUP);
  pinMode(BTN_UP, INPUT_PULLUP);
  pinMode(BTN_DOWN, INPUT_PULLUP);

  lcd.print("System Booting...");
  delay(1000);

  finger.begin(57600);
  if (finger.verifyPassword()) {
    lcd.clear();
    lcd.print("Sensor Found!");
  } else {
    lcd.clear();
    lcd.print("Sensor Error!");
    while (1) { delay(1); }
  }

  delay(1500);
  displayDefaultMessage();
}

void loop() {
  // 1. Constantly scan for fingers in the background
  verifyFinger();

  // 2. Check physical button triggers
  if (digitalRead(BTN_ENROLL) == LOW) {
    delay(200); // Simple debounce
    enrollFingerStandalone();
    displayDefaultMessage();
  }
  
  if (digitalRead(BTN_DELETE) == LOW) {
    delay(200); // Simple debounce
    deleteFingerStandalone();
    displayDefaultMessage();
  }

  delay(50); 
}

void displayDefaultMessage() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("  Place Finger  ");
  lcd.setCursor(0, 1);
  lcd.print(" Ready to Scan  ");
}

// 1. Scanner Mode
void verifyFinger() {
  int p = finger.getImage();
  if (p != FINGERPRINT_OK) return; 

  p = finger.image2Tz();
  if (p != FINGERPRINT_OK) return;

  p = finger.fingerFastSearch();
  if (p == FINGERPRINT_OK) {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("ACCESS GRANTED!");
    lcd.setCursor(0, 1);
    lcd.print("Welcome ID: #");
    lcd.print(finger.fingerID);
    delay(3000); 
  } else {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("ACCESS DENIED!");
    lcd.setCursor(0, 1);
    lcd.print("Unknown User");
    delay(2500);
  }
  displayDefaultMessage();
}

// 2. Standalone UI Enrollment Mode (Using Hardware Buttons)
void enrollFingerStandalone() {
  int targetId = 1;
  lcd.clear();
  
  // Loop to pick the ID using UP/DOWN buttons
  while (true) {
    lcd.setCursor(0, 0);
    lcd.print("Enroll New User ");
    lcd.setCursor(0, 1);
    lcd.print("Select ID: ");
    lcd.print(targetId);
    lcd.print("   "); // Clear trailing characters

    if (digitalRead(BTN_UP) == LOW) {
      targetId++;
      if (targetId > 127) targetId = 1;
      delay(200);
    }
    if (digitalRead(BTN_DOWN) == LOW) {
      targetId--;
      if (targetId < 1) targetId = 127;
      delay(200);
    }
    if (digitalRead(BTN_DELETE) == LOW) {
      // Treat delete button as a 'Cancel' action during setup
      return; 
    }
    if (digitalRead(BTN_ENROLL) == LOW) {
      // Treat enroll button as 'Confirm ID'
      delay(500);
      break; 
    }
  }

  lcd.clear();
  lcd.print("ID: "); lcd.print(targetId);
  lcd.setCursor(0, 1);
  lcd.print("Place Finger...");

  // First Scan Loop
  int p = -1;
  while (p != FINGERPRINT_OK) {
    p = finger.getImage();
    if (digitalRead(BTN_DELETE) == LOW) return; // Allow canceling out
  }
  
  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) return;

  lcd.clear();
  lcd.print("Remove Finger");
  delay(2000);
  p = 0;
  while (p != FINGERPRINT_NOFINGER) {
    p = finger.getImage();
  }

  lcd.clear();
  lcd.print("Place Same Again");
  p = -1;
  while (p != FINGERPRINT_OK) {
    p = finger.getImage();
  }

  // Second Scan Loop
  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) return;

  p = finger.createModel();
  lcd.clear();
  if (p == FINGERPRINT_OK) {
    p = finger.storeModel(targetId);
    if (p == FINGERPRINT_OK) {
      lcd.print("SUCCESS!");
      lcd.setCursor(0, 1);
      lcd.print("Saved to ID #");
      lcd.print(targetId);
    } else {
      lcd.print("Storage Error");
    }
  } else {
    lcd.print("No Match Found");
  }
  delay(2500);
}

// 3. Standalone UI Deletion Mode (Using Hardware Buttons)
void deleteFingerStandalone() {
  int targetId = 1;
  lcd.clear();

  // Loop to pick the ID to wipe
  while (true) {
    lcd.setCursor(0, 0);
    lcd.print("Wipe User Data ");
    lcd.setCursor(0, 1);
    lcd.print("Delete ID: ");
    lcd.print(targetId);
    lcd.print("   "); 

    if (digitalRead(BTN_UP) == LOW) {
      targetId++;
      if (targetId > 127) targetId = 1;
      delay(200);
    }
    if (digitalRead(BTN_DOWN) == LOW) {
      targetId--;
      if (targetId < 1) targetId = 127;
      delay(200);
    }
    if (digitalRead(BTN_ENROLL) == LOW) {
      return; // Cancel out safely
    }
    if (digitalRead(BTN_DELETE) == LOW) {
      delay(500); // Confirm deletion
      break; 
    }
  }

  lcd.clear();
  int p = finger.deleteModel(targetId);
  if (p == FINGERPRINT_OK) {
    lcd.print("ID #"); lcd.print(targetId);
    lcd.setCursor(0, 1);
    lcd.print("Wiped Clean.");
  } else {
    lcd.print("Deletion Failed");
  }
  delay(2500);
}
